// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  // provider = "prisma-client"
  // output   = "../generated/prisma"
  provider = "prisma-client-js" // comente la otras linea porque en config por alguna raon no asia que seme dectectara la ruta y ya probe direrente tipo de ruta y no funcion o esta fue la unica solucion
}

datasource db {
  provider = "sqlite"
}

model Restaurant {
  id Int     @id @default(autoincrement()) 
  name String
  address String
  city String
  cuisineType String
  rating Float
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}